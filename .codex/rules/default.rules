prefix_rule(pattern=["terraform", "init"], decision="allow")
prefix_rule(pattern=["terraform", "validate"], decision="allow")
prefix_rule(pattern=["kubectl"], decision="allow")
prefix_rule(pattern=["/usr/bin/zsh", "-lc", "sops -d ./helm/opencti-helm/secrets/values.enc.yaml >/tmp/opencti-local-values.yaml"], decision="allow")
prefix_rule(pattern=["/usr/bin/zsh", "-lc", "HELM_PLUGINS=\"$PWD/helm/plugins:$(helm env HELM_PLUGINS | sed -E 's/^HELM_PLUGINS=\"(.*)\"$/\\1/')\" helm template opencti-local ./helm/opencti-helm -n cti -f ./helm/opencti-helm/values.yaml -f /tmp/opencti-local-values.yaml --post-renderer kustomize-post-renderer | kubectl apply --dry-run=server -f -"], decision="allow")
prefix_rule(pattern=["helm", "status", "opencti-local", "-n", "cti"], decision="allow")
prefix_rule(pattern=["./helm-deploy.sh"], decision="allow")
prefix_rule(pattern=["sed", "-n", "/Events:/,$p"], decision="allow")
prefix_rule(pattern=["sed", "-n", "/Init Containers:/,/Containers:/p"], decision="allow")
prefix_rule(pattern=["sed", "-n", "/Conditions:/,/Events:/p"], decision="allow")
prefix_rule(pattern=["rtk", "kubectl"], decision="allow")
prefix_rule(pattern=["rtk", "kubectl", "logs"], decision="allow")
