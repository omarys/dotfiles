sed -i -e "s/\r//g"
sed -i -e "s/\e\[[0-9;]*m//g"
%! col -xb

bluetoothctl > scan on > trust > pair > connect

Alias     | Command
----------|----------------------------------------------------------------------------------------
dbl       | docker build
dcin      | docker container inspect
dclsa     | docker container ls -a
dils      | docker image ls
drit      | docker container run --interactive --tty
dsta      | docker stop $(podman ps -q)
dtop      | docker top
gaa       | git add --all
gdup      | git diff @{upstream}
gdw       | git diff --word-diff
ggl       | git pull origin $(current_branch)
ggp       | git push origin $(current_branch)
gpristine | git reset --hard && git clean -dffx
grhh      | git reset --hard
jjbc      | jj bookmark create
jjn       | jj new
jjrb      | jj rebase
jjsq      | jj squash
jjst      | jj status
prcau     | pre-commit autoupdate
prcra     | pre-commit run --all-files
tt        | tofu
tta       | tofu apply
ttc       | tofu console
ttd       | tofu destroy
ttf       | tofu fmt
tti       | tofu init
tto       | tofu output
ttp       | tofu plan
ttr       | tofu refresh
tts       | tofu state
ttsh      | tofu show
ttt       | tofu test
ttv       | tofu validate
ttws      | tofu workspace
uva       | uv add
uvexp     | uv export --format requirements-txt --no-hashes --output-file requirements.txt --quiet
uvlu      | uv lock --upgrade
uvsu      | uv sync --upgrade
uvup      | uv self update
uvv       | uv venv
