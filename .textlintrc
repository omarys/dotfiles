{
  "plugins": {
    "org": true
  },
  "rules": {
    "common-misspellings": true,
    "no-todo": true,
    "write-good": true,
    "terminology": {
      "defaultTerms": true,
      "terms": {
        "Org-mode": "Org mode",
        "Emacs": "Emacs"
      }
    }
  },
  "filters": {
    "comments": true
  }
}
